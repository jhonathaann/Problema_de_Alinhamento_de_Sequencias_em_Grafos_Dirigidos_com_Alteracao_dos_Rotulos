{
    "version": 4,
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:GUROBI_HOME}/include"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${env:GUROBI_HOME}/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            },
            "compilerPath": "C:/MinGW/bin/gcc.exe",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x86"
        }
    ]
}